# .env.example — Lumina
# Copy to .env.local and fill in your actual values
# NEVER commit .env.local — it is gitignored

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ElevenLabs TTS
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_KEY_HERE
ELEVENLABS_VOICE_ID=YOUR_VOICE_ID_HERE

# RevenueCat (iOS public key — safe in binary)
REVENUECAT_API_KEY_IOS=appl_YOUR_KEY_HERE

# OneSignal push notifications
ONESIGNAL_APP_ID=YOUR-UUID-HERE

# Supabase (anon key — safe in binary)
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY_HERE

# Swiss Ephemeris self-hosted service
SWISS_EPH_SERVICE_URL=http://localhost:3001
SWISS_EPH_API_SECRET=generate_with_openssl_rand_hex_32
