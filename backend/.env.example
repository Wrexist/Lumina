# Lumina ephemeris backend — copy to backend/.env for local dev.
# In production these are set via Fly.io secrets / GH Actions secrets.

# Port the Fastify server listens on. Default 3001.
PORT=3001

# Bind address. Default 127.0.0.1 (localhost). Set to 0.0.0.0 in containers.
HOST=127.0.0.1

# Shared secret expected on every /chart request as `X-Lumina-Secret`.
# The iOS app reads this from $(SWISS_EPH_API_SECRET) at build time.
# Generate: `openssl rand -hex 32`
LUMINA_API_SECRET=

# Optional: log level. trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info
